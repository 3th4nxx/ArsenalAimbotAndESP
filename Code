local FlyTab = Window:CreateTab("Fly", 4483362458)

local flying    = false
local flySpeed  = 50
local bVelocity = nil
local bGyro     = nil

local function stopFly()
    flying = false
    if bVelocity then pcall(function() bVelocity:Destroy() end) bVelocity = nil end
    if bGyro     then pcall(function() bGyro:Destroy()     end) bGyro     = nil end
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false end
end

local function startFly()
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    hum.PlatformStand = true

    bGyro = Instance.new("BodyGyro")
    bGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bGyro.CFrame    = hrp.CFrame
    bGyro.P         = 1e4
    bGyro.Parent    = hrp

    bVelocity = Instance.new("BodyVelocity")
    bVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bVelocity.Velocity = Vector3.zero
    bVelocity.P        = 1e4
    bVelocity.Parent   = hrp

    flying = true
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Q then
        if flying then
            stopFly()
            Rayfield:Notify({ Title = "Fly", Content = "Fly disabled.", Duration = 2 })
        else
            startFly()
            Rayfield:Notify({ Title = "Fly", Content = "Fly enabled! WASD + Space/Shift to move.", Duration = 3 })
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not flying or not bVelocity or not bGyro then return end
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not bVelocity.Parent then stopFly() return end

    local dir = Vector3.zero
    if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir += Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir -= Camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir -= Camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir += Camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir += Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0, 1, 0) end

    bVelocity.Velocity = dir * flySpeed
    bGyro.CFrame       = Camera.CFrame
end)

LocalPlayer.CharacterAdded:Connect(function()
    flying    = false
    bVelocity = nil
    bGyro     = nil
end)

