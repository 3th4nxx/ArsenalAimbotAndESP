local AimbotTab = Window:CreateTab("Aimbot", 4483362458)

local aimbotEnabled   = false
local aimbotFOV       = 200
local aimbotSmooth    = 0.15
local aimbotTeamCheck = true

local function getAimbotTarget()
    local closest, closestDist = nil, aimbotFOV
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if aimbotTeamCheck and not isEnemy(p) then continue end

        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        local aimPoint = hrp.Position + Vector3.new(0, 1.5, 0)

        -- Build exclusion list: all player characters so we dont hit them as walls
        local excludeList = {}
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl.Character then
                table.insert(excludeList, pl.Character)
            end
        end
        rayParams.FilterDescendantsInstances = excludeList

        -- Cast ray from camera position toward the target
        local origin    = Camera.CFrame.Position
        local direction = (aimPoint - origin)
        local result    = workspace:Raycast(origin, direction, rayParams)

        -- If raycast hit something before reaching the target, they're behind a wall
        if result then
            -- Something was hit before we reached the player → skip
            continue
        end

        local screenPos, onScreen = Camera:WorldToViewportPoint(aimPoint)
        if onScreen and screenPos.Z > 0 then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = hrp
            end
        end
    end
    return closest
end

local lastCFrame = nil

RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then
        lastCFrame = nil
        return
    end

    if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        lastCFrame = nil
        return
    end

    local target = getAimbotTarget()
    if not target then return end

    local aimPoint   = target.Position + Vector3.new(0, 1.5, 0)
    local currentPos = Camera.CFrame.Position
    local targetCF   = CFrame.new(currentPos, aimPoint)
    local smoothed   = Camera.CFrame:Lerp(targetCF, aimbotSmooth)

    Camera.CFrame     = smoothed
    Camera.CameraType = Enum.CameraType.Custom
end)

