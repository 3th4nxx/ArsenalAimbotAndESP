local highlights   = {}
local fillColor    = Color3.fromRGB(255, 100, 0)
local outlineColor = Color3.fromRGB(255, 255, 255)
local fillTrans    = 0.5
local outlineTrans = 0

-- ============================================================
--  TEAM HELPERS
-- ============================================================
local function getOwnerTeam()
    if LocalPlayer.Team then return LocalPlayer.Team end
    for _, team in ipairs(Teams:GetTeams()) do
        for _, p in ipairs(team:GetPlayers()) do
            if p == LocalPlayer then return team end
        end
    end
    return nil
end

local function isEnemy(player)
    if player == LocalPlayer then return false end
    local myTeam = getOwnerTeam()
    if not myTeam then return true end
    return player.Team ~= myTeam
end

-- ============================================================
--  HIGHLIGHT HELPERS
-- ============================================================
local function applyHighlight(player, char)
    local hl = Instance.new("Highlight")
    hl.FillColor           = fillColor
    hl.OutlineColor        = outlineColor
    hl.FillTransparency    = fillTrans
    hl.OutlineTransparency = outlineTrans
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee             = char
    hl.Parent              = char
    highlights[player.Name] = hl
end

local function addHighlight(player)
    if highlights[player.Name] then
        pcall(function() highlights[player.Name]:Destroy() end)
        highlights[player.Name] = nil
    end
    local char = player.Character
    if char then applyHighlight(player, char) end
    player.CharacterAdded:Connect(function(newChar)
        task.wait()
        if isEnemy(player) then
            applyHighlight(player, newChar)
        end
    end)
end

local function removeHighlight(player)
    if highlights[player.Name] then
        pcall(function() highlights[player.Name]:Destroy() end)
        highlights[player.Name] = nil
    end
end

local function refreshColors()
    for _, hl in pairs(highlights) do
        pcall(function()
            hl.FillColor           = fillColor
            hl.OutlineColor        = outlineColor
            hl.FillTransparency    = fillTrans
            hl.OutlineTransparency = outlineTrans
        end)
    end
end

Players.PlayerRemoving:Connect(function(p) highlights[p.Name] = nil end)

local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.UserId ~= OWNER_USER_ID then
            table.insert(names, p.Name)
        end
    end
    return #names > 0 and names or {"(No other players)"}
end

