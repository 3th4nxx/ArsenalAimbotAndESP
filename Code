local espEnabled  = false
local espBoxes    = {}
local espColor    = Color3.fromRGB(255, 0, 0)
local espShowName = true
local espShowHP   = true

local espGui = Instance.new("ScreenGui")
espGui.Name           = "OwnerESP"
espGui.ResetOnSpawn   = false
espGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
espGui.Parent         = LocalPlayer.PlayerGui

local function removeBox(player)
    if espBoxes[player.Name] then
        pcall(function() espBoxes[player.Name].frame:Destroy() end)
        espBoxes[player.Name] = nil
    end
end

local function createBox(player)
    if player == LocalPlayer or espBoxes[player.Name] then return end

    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel        = 0
    frame.Size                   = UDim2.new(0, 50, 0, 80)
    frame.Visible                = false
    frame.Parent                 = espGui

    local function makeLine(sX, sY, pX, pY)
        local l = Instance.new("Frame")
        l.BackgroundColor3 = espColor
        l.BorderSizePixel  = 0
        l.Size             = UDim2.new(sX, 2, sY, 2)
        l.Position         = UDim2.new(pX, 0, pY, 0)
        l.Parent           = frame
    end

    makeLine(1, 0, 0, 0) -- top
    makeLine(1, 0, 0, 1) -- bottom
    makeLine(0, 1, 0, 0) -- left
    makeLine(0, 1, 1, 0) -- right

    -- Fix line thickness
    local children = frame:GetChildren()
    -- top & bottom: full width, 2px tall
    children[1].Size = UDim2.new(1, 0, 0, 2)
    children[2].Size = UDim2.new(1, 0, 0, 2)
    -- left & right: 2px wide, full height
    children[3].Size = UDim2.new(0, 2, 1, 0)
    children[4].Size = UDim2.new(0, 2, 1, 0)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.BackgroundTransparency = 1
    nameLabel.Size                   = UDim2.new(1, 0, 0, 14)
    nameLabel.Position               = UDim2.new(0, 0, 0, -16)
    nameLabel.TextColor3             = espColor
    nameLabel.TextSize               = 13
    nameLabel.Font                   = Enum.Font.GothamBold
    nameLabel.Text                   = player.Name
    nameLabel.TextStrokeTransparency = 0
    nameLabel.Parent                 = frame

    local hpLabel = Instance.new("TextLabel")
    hpLabel.BackgroundTransparency = 1
    hpLabel.Size                   = UDim2.new(1, 0, 0, 14)
    hpLabel.Position               = UDim2.new(0, 0, 1, 2)
    hpLabel.TextColor3             = Color3.fromRGB(100, 255, 100)
    hpLabel.TextSize               = 12
    hpLabel.Font                   = Enum.Font.Gotham
    hpLabel.Text                   = "HP: ?"
    hpLabel.TextStrokeTransparency = 0
    hpLabel.Parent                 = frame

    espBoxes[player.Name] = { frame = frame, nameLabel = nameLabel, hpLabel = hpLabel }
end

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _, data in pairs(espBoxes) do
            pcall(function() data.frame.Visible = false end)
        end
        return
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local data = espBoxes[player.Name]
        if not data then continue end

        -- Skip teammates
        if not isEnemy(player) then
            data.frame.Visible = false
            continue
        end

        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")

        if not hrp then data.frame.Visible = false continue end

        local head    = char:FindFirstChild("Head")
        local topPart = head or hrp
        local topPos  = topPart.Position + Vector3.new(0, topPart.Size.Y / 2 + 0.1, 0)
        local botPos  = hrp.Position - Vector3.new(0, 3.2, 0)

        local topScreen, topVis = Camera:WorldToViewportPoint(topPos)
        local botScreen         = Camera:WorldToViewportPoint(botPos)

        if not topVis or topScreen.Z < 0 then
            data.frame.Visible = false
            continue
        end

        local height = math.abs(botScreen.Y - topScreen.Y)
        local width  = height * 0.55
        local left   = topScreen.X - width / 2
        local top    = topScreen.Y

        data.frame.Visible  = true
        data.frame.Position = UDim2.new(0, left, 0, top)
        data.frame.Size     = UDim2.new(0, width, 0, height)

        for _, child in ipairs(data.frame:GetChildren()) do
            if child:IsA("Frame") then
                child.BackgroundColor3 = espColor
            end
        end

        data.nameLabel.Visible    = espShowName
        data.nameLabel.Text       = player.Name
        data.nameLabel.TextColor3 = espColor

        data.hpLabel.Visible = espShowHP
        if hum then
            local pct = math.floor((hum.Health / hum.MaxHealth) * 100)
            data.hpLabel.Text       = "HP: " .. pct .. "%"
            data.hpLabel.TextColor3 = Color3.fromRGB(
                math.floor(255 * (1 - hum.Health / hum.MaxHealth)),
                math.floor(255 * (hum.Health / hum.MaxHealth)),
                0
            )
        end
    end
end)

